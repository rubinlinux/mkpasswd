---
import '../styles/global.css'
import HashApp from '../components/HashApp.vue'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const favicon = `${base}/favicon.svg`
// absolute URLs for social-card crawlers, which don't resolve relative paths
const canonical = new URL(import.meta.env.BASE_URL, Astro.site ?? 'https://rubinlinux.github.io').href
const ogImage = new URL(`${base}/og.png`, Astro.site ?? 'https://rubinlinux.github.io').href
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href={favicon} type="image/svg+xml" />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />
    <link rel="apple-touch-icon" href={`${base}/icon-192.png`} />
    <meta name="theme-color" content="#ece9d8" />
    <title>mkpasswd — generate password hashes in your browser</title>
    <meta
      name="description"
      content="Generate 100+ kinds of password hashes entirely in your browser. Nothing is ever sent to a server — every hash is computed locally with JavaScript and WebAssembly."
    />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content="mkpasswd — client-side password hashes" />
    <meta property="og:description" content="115+ hash algorithms — generated, identified & verified locally. Your password never leaves the page." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="mkpasswd — client-side password hashes" />
    <meta name="twitter:description" content="115+ hash algorithms — generated, identified & verified locally. Your password never leaves the page." />
    <meta name="twitter:image" content={ogImage} />
    <meta name="color-scheme" content="light dark" />
  </head>
  <body>
    <HashApp client:load />
    <noscript>
      <p style="padding:2rem;text-align:center;font-family:sans-serif">
        This tool runs entirely in your browser and needs JavaScript enabled.
      </p>
    </noscript>
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register(`${import.meta.env.BASE_URL.replace(/\/$/, '')}/sw.js`)
            .catch(() => { /* offline support is best-effort */ })
        })
      }
    </script>
  </body>
</html>
